{
  "name": "agenty",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "cli:build": "turbo run build --filter=agenty-cli",
    "cli:dev": "pnpm --filter agenty-cli dev",
    "cli:typecheck": "pnpm --filter agenty-cli typecheck",
    "runtime:build": "turbo run build --filter=agenty-runtime"
  },
  "packageManager": "pnpm@11.1.3",
  "devDependencies": {
    "turbo": "^2"
  }
}
