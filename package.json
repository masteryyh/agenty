{
  "name": "agenty",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build && mkdir -p dist && cp packages/agenty-bootstrap/bin/* dist/ 2>/dev/null || true",
    "test": "turbo run test",
    "dev": "pnpm cli:dev",
    "clean": "rm -rf dist && turbo run clean",
    "deepclean": "pnpm clean && rm -rf node_modules packages/*/node_modules",
    "core:build": "turbo run build --filter=agenty-core",
    "core:test": "turbo run test --filter=agenty-core",
    "core:test:integration": "pnpm --filter agenty-core test:integration",
    "core:test:e2e": "pnpm --filter agenty-core test:e2e",
    "core:test:e2e:race": "pnpm --filter agenty-core test:e2e:race",
    "core:test:race": "pnpm --filter agenty-core test:race",
    "core:test:repeat": "pnpm --filter agenty-core test:repeat",
    "core:tidyup": "cd packages/agenty-core && go fmt ./... && go vet ./... && go mod tidy",
    "core:clean": "pnpm --filter agenty-core clean",
    "cli:build": "turbo run build --filter=agenty-cli",
    "cli:dev": "turbo run build --filter=agenty-runtime && pnpm --filter agenty-cli dev",
    "cli:typecheck": "pnpm --filter agenty-cli typecheck",
    "cli:clean": "pnpm --filter agenty-cli clean",
    "runtime:build": "turbo run build --filter=agenty-runtime",
    "runtime:dev": "cd packages/agenty-runtime && CGO_ENABLED=1 go run -tags=fts5 -ldflags \"-X github.com/masteryyh/agenty/pkg/version.Version=${AGENTY_VERSION:-dev}\" ./cmd/main.go",
    "runtime:tidyup": "cd packages/agenty-runtime && go fmt ./... && go vet ./... && go mod tidy",
    "runtime:clean": "pnpm --filter agenty-runtime clean",
    "bootstrap:build": "turbo run build --filter=agenty-bootstrap",
    "bootstrap:test": "turbo run test --filter=agenty-bootstrap",
    "bootstrap:clean": "pnpm --filter agenty-bootstrap clean"
  },
  "packageManager": "pnpm@11.1.3",
  "devDependencies": {
    "turbo": "^2.10.5"
  }
}
