{
  "$schema": "https://v2-10-5.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["bin/**", "dist/**"],
      "env": ["GOOS", "GOARCH", "CC", "CXX", "PACKAGE_DIR", "BIN_NAME", "VERSION"]
    },
    "agenty-cli#build": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["OS", "ARCH", "OPENTUI_LIBC", "AGENTY_CLI_VERSION"]
    },
    "agenty-bootstrap#build": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["OS", "ARCH"],
      "passThroughEnv": ["HOME", "CARGO_HOME", "RUSTUP_HOME"],
      "outputs": ["dist/**"]
    },
    "agenty-bootstrap#test": {
      "passThroughEnv": ["HOME", "CARGO_HOME", "RUSTUP_HOME"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "typecheck": {}
  }
}
