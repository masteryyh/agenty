{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["bin/**", "dist/**"],
      "env": ["GOOS", "GOARCH", "CC", "CXX", "PACKAGE_DIR", "BIN_NAME", "VERSION"]
    },
    "agenty-cli#build": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["OS", "ARCH", "OPENTUI_LIBC", "AGENTY_CLI_VERSION"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {}
  }
}
