{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch agenty in daemon mode",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/main.go",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": ["--daemon"],
            "buildFlags": ["-tags=fts5"]
        },
        {
            "name": "Launch agenty in local mode",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/main.go",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "buildFlags": ["-tags=fts5"]
        },
        {
            "name": "Launch agenty in client mode",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/main.go",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": ["--config", "agenty-client.yaml"]
        }
    ]
}