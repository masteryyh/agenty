{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch agenty in server mode",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": ["--server", "--config", "agenty.yaml"],
            "buildFlags": ["-tags=fts5"]
        },
        {
            "name": "Launch agenty in local mode",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": ["--config", "agenty.yaml"],
            "buildFlags": ["-tags=fts5"]
        },
        {
            "name": "Launch agenty in client mode",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": ["--config", "agenty-client.yaml"],
            "buildFlags": ["-tags=fts5"]
        }
    ]
}
