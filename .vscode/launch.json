{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch agenty server",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": ["--debug"],
            "buildFlags": ["-tags=fts5"]
        },
        // agenty-cli TUI debug. Requires the Bun VS Code extension (oven-sh.bun-vscode).
        // Local mode starts its own embedded agenty server.
        {
            "name": "Launch agenty-cli (bun)",
            "type": "bun",
            "request": "launch",
            "program": "${workspaceFolder}/agenty-cli/src/index.tsx",
            "cwd": "${workspaceFolder}",
            "args": [],
            "runtime": "bun"
        }
    ]
}
