{
  "name": "agenty-runtime",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "mkdir -p \"${PACKAGE_DIR:-bin}\" && go build -tags=fts5 -ldflags \"-X github.com/masteryyh/agenty/pkg/version.Version=${AGENTY_VERSION:-dev}\" -o \"${PACKAGE_DIR:-bin}/${BIN_NAME:-agenty}\" ./cmd/main.go",
    "test": "go test ./...",
    "vet": "go vet ./...",
    "fmt": "go fmt ./...",
    "clean": "rm -rf bin"
  }
}
