{
  "name": "agenty-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun run scripts/ensure-embedded.ts && bun run src/index.tsx",
    "start": "bun run scripts/ensure-embedded.ts && bun run src/index.tsx",
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist agenty.log"
  },
  "dependencies": {
    "@opentui/core": "0.4.3",
    "@opentui/react": "0.4.3",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "ws": "8.18.3",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "agenty-runtime": "workspace:*",
    "typescript": "^6.0.3"
  }
}
